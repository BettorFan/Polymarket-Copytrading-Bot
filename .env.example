# Required
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
TARGET_WALLET=0xTARGET_WALLET_TO_COPY

# Optional: per-target order size for .env mode (default: 1)
# If omitted, falls back to MAX_ORDER_AMOUNT when present.
TARGET_WALLET_ORDER_SIZE=2
# Backward-compatible fallback used by this repo
MAX_ORDER_AMOUNT=2

# Trading mode
ENABLE_COPY_TRADING=true
DRY_RUN=false
ORDER_TYPE=FAK
ORDER_SIZE_IN_TOKENS=true

# Network
CHAIN_ID=137
CLOB_API_URL=https://clob.polymarket.com
# Optional, if your provider requires API key:
# RPC_TOKEN=your_alchemy_or_rpc_token
# Or direct URL:
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key

# Optional: set explicitly; if empty bot auto-resolves from your EOA
PROXY_WALLET_ADDRESS=

# Strategy params
BUY_THRESHOLD=0.45
SELL_PRICE=0.35
PROFIT_SELL_THRESHOLD=0.99
PENDING_BUY_TIME_THRESHOLD_SECONDS=160
REDEEM_DURATION=120